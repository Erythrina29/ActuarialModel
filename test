def calculate_annuity_factor(df, mortality_table, config, yield_curve=None):
    """
    Calculate waiver annuity factor.

    Key governance points:
    1. Currency must already exist in the model point.
    2. Currency is normalized before RFR lookup.
    3. interest_rate config keys are normalized before lookup.
    4. No silent fallback to i = 0.05.
    5. Existing annuity timing is preserved first: annuity += surv * (v ** k).
    """

    basis = str(config.get("basis", "Local")).strip()

    if basis != "Local":
        raise NotImplementedError(
            "calculate_annuity_factor() saat ini hanya diaktifkan untuk basis Local. "
            "Basis selain Local perlu dicek terpisah agar tidak salah memakai yield curve."
        )

    result = df.copy()

    if "Currency" not in result.columns:
        raise ValueError(
            "Column 'Currency' tidak ditemukan di model point. "
            "Untuk waiver reserve ini, Currency tidak boleh di-derive dari PROD_CODE."
        )

    result["Currency"] = result["Currency"].apply(normalize_currency)

    invalid_currency = result[
        result["Currency"].isna()
        | ~result["Currency"].isin(["IDR", "USD"])
    ].copy()

    if len(invalid_currency) > 0:
        sample_cols = [
            col
            for col in ["policy_number", "Currency"]
            if col in invalid_currency.columns
        ]

        raise ValueError(
            "Ada Currency yang tidak valid sebelum annuity calculation. "
            f"Jumlah rows: {len(invalid_currency):,}. "
            f"Sample: {invalid_currency[sample_cols].head(20).to_dict('records')}"
        )

    interest_rates_raw = config.get("interest_rate")

    if interest_rates_raw is None:
        raise ValueError(
            "Config tidak punya key 'interest_rate'. "
            "Pastikan YAML berisi interest_rate dengan key IDR dan USD."
        )

    interest_rates = {}

    for key, value in interest_rates_raw.items():
        normalized_key = normalize_currency(key)

        if pd.isna(normalized_key):
            continue

        try:
            interest_rates[normalized_key] = float(value)
        except Exception as exc:
            raise ValueError(
                f"Interest rate untuk key '{key}' tidak bisa dikonversi menjadi angka. "
                f"Value aktual: {value}"
            ) from exc

    missing_rate_keys = {"IDR", "USD"} - set(interest_rates.keys())

    if missing_rate_keys:
        raise ValueError(
            f"interest_rate config belum lengkap. Missing keys: {missing_rate_keys}. "
            f"Available keys after normalization: {list(interest_rates.keys())}"
        )

    mortality_table = mortality_table.copy()

    if "Age" not in mortality_table.columns:
        raise ValueError(
            "Mortality table tidak punya column 'Age'."
        )

    mortality_table["Age"] = pd.to_numeric(
        mortality_table["Age"],
        errors="coerce",
    )

    required_mortality_cols = ["MNSQ[x]", "FNSQ[x]"]

    missing_mortality_cols = [
        col
        for col in required_mortality_cols
        if col not in mortality_table.columns
    ]

    if missing_mortality_cols:
        raise ValueError(
            f"Mortality table missing columns: {missing_mortality_cols}"
        )

    sex_column_candidates = [
        "Sex",
        "SEX",
        "Insured_Sex",
        "INSURED_SEX",
        "Gender",
        "GENDER",
    ]

    sex_column = None

    for col in sex_column_candidates:
        if col in result.columns:
            sex_column = col
            break

    if sex_column is None:
        raise ValueError(
            "Tidak ditemukan column sex/gender di model point. "
            f"Expected salah satu dari: {sex_column_candidates}"
        )

    required_model_cols = [
        "current_age_at_val",
        "remaining_waiver_years",
        "Currency",
        sex_column,
    ]

    missing_model_cols = [
        col
        for col in required_model_cols
        if col not in result.columns
    ]

    if missing_model_cols:
        raise ValueError(
            f"Model point missing columns untuk annuity calculation: {missing_model_cols}"
        )

    def get_annuity(row):
        age = row["current_age_at_val"]
        remaining = row["remaining_waiver_years"]
        sex = str(row[sex_column]).strip().upper()
        currency = normalize_currency(row["Currency"])

        if pd.isna(age):
            raise ValueError(
                f"current_age_at_val kosong untuk policy_number={row.get('policy_number')}"
            )

        if pd.isna(remaining):
            raise ValueError(
                f"remaining_waiver_years kosong untuk policy_number={row.get('policy_number')}"
            )

        if pd.isna(currency):
            raise ValueError(
                f"Currency kosong untuk policy_number={row.get('policy_number')}"
            )

        if currency not in interest_rates:
            raise ValueError(
                f"Currency '{currency}' tidak ditemukan di interest_rate config. "
                f"Available keys: {list(interest_rates.keys())}. "
                f"policy_number={row.get('policy_number')}"
            )

        age = float(age)
        remaining = int(remaining)

        if remaining <= 0:
            return 0.0

        i = interest_rates[currency]
        v = 1 / (1 + i)

        if sex in ["M", "MALE", "L", "LAKI-LAKI", "LAKILAKI"]:
            q_col = "MNSQ[x]"
        elif sex in ["F", "FEMALE", "P", "PEREMPUAN", "WANITA"]:
            q_col = "FNSQ[x]"
        else:
            raise ValueError(
                f"Sex/Gender tidak valid: '{sex}' "
                f"untuk policy_number={row.get('policy_number')}"
            )

        surv = 1.0
        annuity = 0.0

        for k in range(remaining):
            # Keep existing annuity timing first.
            # Do not change to v ** (k + 1) until RFR lookup is fully validated.
            annuity += surv * (v ** k)

            current_age = int(round(age + k))

            q_row = mortality_table[
                mortality_table["Age"] == current_age
            ]

            if len(q_row) > 0:
                q = q_row.iloc[0][q_col]
            else:
                q = 0.01

            q = float(q)

            if q < 0 or q > 1:
                raise ValueError(
                    f"Invalid qx={q} untuk age={current_age}, q_col={q_col}, "
                    f"policy_number={row.get('policy_number')}"
                )

            surv *= 1 - q

        return annuity

    result["annuity_factor"] = result.apply(get_annuity, axis=1)

    logger.info(
        "Annuity factor calculated using Local basis. Interest rates used: %s",
        interest_rates,
    )

    logger.info(
        "Currency distribution in annuity calculation: %s",
        result["Currency"].value_counts(dropna=False).to_dict(),
    )

    return result
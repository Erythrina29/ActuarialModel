"""
MIDDLE SECTION: Waiver reserve orchestration engine.

This version includes:
1. Explicit AOM scenario assumption override via scenario_config.
2. Annual premium waived in both original policy currency and IDR.
3. IDR reporting convention: annual_premium_waived is overwritten to IDR after
   annual_premium_waived_ccy is preserved for audit.
"""

from __future__ import annotations

import logging
from copy import deepcopy
from datetime import datetime
from typing import Any, Dict, Optional

import pandas as pd

from waiver_reserve.model import (
    calculate_age_and_remaining_term,
    calculate_annual_premium_waived,
    calculate_annuity_factor,
    enrich_waiver_data,
)

logger = logging.getLogger("waiver_reserve.reserve_engine")


def _normalize_currency_for_fx(value: object) -> str:
    """
    Normalize currency values only for FX/reporting conversion.

    Note:
    Currency source itself must already be provided by the official model point.
    This helper does not derive currency from PROD_CODE.
    """
    if pd.isna(value):
        return ""

    ccy = str(value).strip().upper().replace(" ", "")

    mapping = {
        "IDR": "IDR",
        "RP": "IDR",
        "RUPIAH": "IDR",
        "R": "IDR",
        "USD": "USD",
        "US$": "USD",
        "US": "USD",
        "U": "USD",
        "DOLLAR": "USD",
    }

    return mapping.get(ccy, ccy)


def build_scenario_config(
    base_config: Dict[str, Any],
    interest_rates: Optional[Dict[str, float]] = None,
    usd_to_idr_rate: Optional[float] = None,
    valuation_date: Optional[str] = None,
    basis: Optional[str] = None,
) -> Dict[str, Any]:
    """
    Build explicit scenario config for reserve calculation.

    This fixes the common bug where interest_rates are passed to a helper but
    annuity calculation still reads old rates from config.
    """
    config = deepcopy(base_config)

    if interest_rates is not None:
        config["interest_rate"] = deepcopy(interest_rates)

    if usd_to_idr_rate is not None:
        config["usd_to_idr_rate"] = usd_to_idr_rate

    if valuation_date is not None:
        config["valuation_date"] = valuation_date

    if basis is not None:
        config["basis"] = basis

    return config


def calculate_waiver_reserve(
    data: Dict[str, pd.DataFrame],
    config: Dict[str, Any],
    run_id: str,
    scenario_name: str = "BASE",
    interest_rates: Optional[Dict[str, float]] = None,
    usd_to_idr_rate: Optional[float] = None,
    valuation_date: Optional[str] = None,
    yield_curve: Optional[pd.DataFrame] = None,
) -> pd.DataFrame:
    """
    Calculate waiver reserve for one scenario.

    Parameters with explicit override are used for AOM bridge scenarios.

    Important output convention:
    - annual_premium_waived_ccy: original policy currency amount.
    - annual_premium_waived_idr: reporting amount in IDR.
    - annual_premium_waived: overwritten to IDR for final monthly reserve export
      compatibility, after original amount is preserved in annual_premium_waived_ccy.
    """
    scenario_config = build_scenario_config(
        base_config=config,
        interest_rates=interest_rates,
        usd_to_idr_rate=usd_to_idr_rate,
        valuation_date=valuation_date,
    )

    valuation_date_used = scenario_config.get("valuation_date")
    fx_rate_used = float(scenario_config.get("usd_to_idr_rate", 1.0))
    basis_used = scenario_config.get("basis", "Local")

    logger.info("=== Calculate waiver reserve | scenario=%s ===", scenario_name)
    logger.info(
        "valuation_date=%s | basis=%s | usd_to_idr_rate=%s",
        valuation_date_used,
        basis_used,
        fx_rate_used,
    )

    if yield_curve is None:
        yield_curve = data.get("ifrs17_yield_curve")

    df = enrich_waiver_data(data, scenario_config)
    df = calculate_annual_premium_waived(df, scenario_config)
    df = calculate_age_and_remaining_term(df, valuation_date_used)
    df = calculate_annuity_factor(
        df=df,
        mortality_table=data["mortality_table"],
        config=scenario_config,
        yield_curve=yield_curve,
    )

    if "Currency" not in df.columns:
        raise KeyError(
            "Column 'Currency' is missing after model enrichment. "
            "Currency must be supplied by the official source; do not derive from PROD_CODE."
        )

    df["Currency"] = df["Currency"].apply(_normalize_currency_for_fx)

    invalid_currency = df[~df["Currency"].isin(["IDR", "USD"])].copy()
    if len(invalid_currency) > 0:
        sample_cols = [
            col
            for col in ["policy_number", "Currency"]
            if col in invalid_currency.columns
        ]
        raise ValueError(
            "Invalid Currency values found before FX conversion. "
            f"Rows: {len(invalid_currency):,}. "
            f"Sample: {invalid_currency[sample_cols].head(20).to_dict('records')}"
        )

    df["fx_rate_used"] = df["Currency"].apply(
        lambda ccy: fx_rate_used if ccy == "USD" else 1.0
    )

    # Preserve original currency premium for audit.
    df["annual_premium_waived_ccy"] = pd.to_numeric(
        df["annual_premium_waived"],
        errors="coerce",
    ).fillna(0.0)

    if "annual_basic_premium" in df.columns:
        df["annual_basic_premium_ccy"] = pd.to_numeric(
            df["annual_basic_premium"],
            errors="coerce",
        ).fillna(0.0)
        df["annual_basic_premium_idr"] = (
            df["annual_basic_premium_ccy"] * df["fx_rate_used"]
        )

    if "annual_rider_premium" in df.columns:
        df["annual_rider_premium_ccy"] = pd.to_numeric(
            df["annual_rider_premium"],
            errors="coerce",
        ).fillna(0.0)
        df["annual_rider_premium_idr"] = (
            df["annual_rider_premium_ccy"] * df["fx_rate_used"]
        )

    # Reporting currency premium.
    df["annual_premium_waived_idr"] = (
        df["annual_premium_waived_ccy"] * df["fx_rate_used"]
    )

    # Reserve in original policy currency.
    df["waiver_reserve_base"] = (
        df["annuity_factor"] * df["annual_premium_waived_ccy"]
    )

    # Reserve in reporting currency.
    df["waiver_reserve_idr"] = (
        df["annuity_factor"] * df["annual_premium_waived_idr"]
    )

    # Final monthly reserve output compatibility:
    # annual_premium_waived is now the IDR reporting amount.
    # The original amount is preserved in annual_premium_waived_ccy.
    df["annual_premium_waived"] = df["annual_premium_waived_idr"]

    # Audit columns.
    df["run_id"] = run_id
    df["scenario_name"] = scenario_name
    df["calculation_timestamp"] = datetime.now()
    df["valuation_date_used"] = valuation_date_used
    df["basis_used"] = basis_used
    df["usd_to_idr_rate_used"] = fx_rate_used

    interest_rate = scenario_config.get("interest_rate", {})
    df["interest_rate_idr_used"] = interest_rate.get("IDR") if isinstance(interest_rate, dict) else None
    df["interest_rate_usd_used"] = interest_rate.get("USD") if isinstance(interest_rate, dict) else None

    logger.info("Scenario %s total reserve: %.2f", scenario_name, df["waiver_reserve_idr"].sum())
    logger.info(
        "Scenario %s annual premium waived IDR total: %.2f",
        scenario_name,
        df["annual_premium_waived_idr"].sum(),
    )

    return df
